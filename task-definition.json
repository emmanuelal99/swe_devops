{
  "family": "logitrack-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::344121726575:role/ecsTaskExecutionRole",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "logitrack-web",
      "image": "344121726575.dkr.ecr.eu-west-2.amazonaws.com/logitrack-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DEBUG", "value": "False" },
        { "name": "DB_HOST", "value": "logitrack-db.cz8gqsoc0ec9.eu-west-2.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "logitrack-db" },
        { "name": "DB_USER", "value": "logitrack_devops" },
        { "name": "DB_PASSWORD", "value": "DB_PASSWORD" },
        { "name": "CELERY_BROKER_URL", "value": "redis://your-elasticache-endpoint.eu-west-2.cache.amazonaws.com:6379/0" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/logitrack",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}